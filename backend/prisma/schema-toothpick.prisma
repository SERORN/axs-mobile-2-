// ToothPick Dental Marketplace Schema
// Based on technical brief requirements

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== CORE USER & ORGANIZATION ENTITIES =====

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         String   // ADMIN, PROVIDER, DISTRIBUTOR, CLIENT
  orgId        String?  // null for platform admin
  status       String   @default("ACTIVE") // ACTIVE, SUSPENDED, DELETED
  verified     Boolean  @default(false)
  twoFAEnabled Boolean  @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organization   Organization? @relation(fields: [orgId], references: [id])
  orders         Order[]
  reviews        Review[]
  loyaltyEvents  LoyaltyEvent[]
  referrals      Referral[]     @relation("ReferredUser")
  referredBy     Referral[]     @relation("ReferrerUser")
  auditLogs      AuditLog[]
  exportJobs     ExportJob[]

  @@map("users")
}

model Organization {
  id                String   @id @default(cuid())
  type              String   // PROVIDER, DISTRIBUTOR
  name              String
  slug              String   @unique
  rfc               String?  // Mexico tax ID
  legalName         String?
  country           String   @default("MX")
  currency          String   @default("MXN")
  status            String   @default("PENDING") // PENDING, APPROVED, SUSPENDED
  billingData       Json?    // Address, billing info
  payoutData        Json?    // Bank account, payment preferences
  subscriptionPlan  String   @default("FREE") // FREE, PRO, ELITE
  subscriptionStatus String  @default("ACTIVE")
  subscriptionStartedAt DateTime?
  subscriptionRenewsAt  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  users             User[]
  products          Product[]
  ordersAsSeller    Order[]        @relation("SellerOrg")
  ordersAsBuyer     Order[]        @relation("BuyerOrg")
  quotesAsSeller    Quote[]        @relation("SellerOrgQuote")
  quotesAsRequester Quote[]        @relation("RequesterOrgQuote")
  invoices          Invoice[]
  subscriptions     Subscription[]
  commissions       Commission[]
  loyaltyEvents     LoyaltyEvent[]

  @@map("organizations")
}

// ===== PRODUCT CATALOG ENTITIES =====

model Product {
  id             String   @id @default(cuid())
  providerId     String
  name           String
  slug           String   @unique
  descriptionI18n Json    // {es: "", en: "", pt: ""}
  categoryId     String
  brand          String?
  sku            String?  @unique
  barcode        String?
  attributes     Json?    // Custom attributes as JSON
  images         String[] // Array of image URLs
  requiresQuote  Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  provider       Organization @relation(fields: [providerId], references: [id])
  category       Category     @relation(fields: [categoryId], references: [id])
  variants       Variant[]
  reviews        Review[]
  quotes         Quote[]

  @@map("products")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  nameI18n    Json     // {es: "", en: "", pt: ""}
  slug        String   @unique
  parentId    String?
  level       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@map("categories")
}

model Variant {
  id          String   @id @default(cuid())
  productId   String
  options     Json     // {size: "Large", color: "Blue"}
  priceBase   Decimal  @db.Decimal(10, 2)
  currency    String   @default("MXN")
  weight      Decimal? @db.Decimal(8, 3)
  dimensions  Json?    // {length, width, height}
  stock       Int      @default(0)
  minQty      Int      @default(1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  product           Product             @relation(fields: [productId], references: [id])
  priceTiers        PriceTier[]
  inventoryMovements InventoryMovement[]
  orderItems        OrderItem[]
  cartItems         CartItem[]

  @@map("variants")
}

model PriceTier {
  id        String   @id @default(cuid())
  variantId String
  minQty    Int
  price     Decimal  @db.Decimal(10, 2)
  currency  String   @default("MXN")
  createdAt DateTime @default(now())

  // Relations
  variant   Variant @relation(fields: [variantId], references: [id])

  @@unique([variantId, minQty])
  @@map("price_tiers")
}

model InventoryMovement {
  id        String   @id @default(cuid())
  variantId String
  change    Int      // positive for addition, negative for subtraction
  reason    String   // PURCHASE, SALE, ADJUSTMENT, RETURN
  reference String?  // Order ID, adjustment reason, etc.
  createdAt DateTime @default(now())

  // Relations
  variant   Variant @relation(fields: [variantId], references: [id])

  @@map("inventory_movements")
}

// ===== CART & ORDER ENTITIES =====

model Cart {
  id        String   @id @default(cuid())
  userId    String?  // null for guest carts
  sessionId String?  // for guest carts
  currency  String   @default("MXN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  variantId String
  qty       Int
  unitPrice Decimal  @db.Decimal(10, 2)
  currency  String   @default("MXN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart      Cart    @relation(fields: [cartId], references: [id])
  variant   Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model Order {
  id                String   @id @default(cuid())
  type              String   // B2B, B2C
  buyerOrgId        String?  // null for B2C, required for B2B
  buyerUserId       String?  // for B2C orders
  sellerOrgId       String
  status            String   @default("PENDING") // PENDING, CONFIRMED, FULFILLED, CANCELLED
  currency          String   @default("MXN")
  subtotal          Decimal  @db.Decimal(10, 2)
  taxes             Decimal  @db.Decimal(10, 2) @default(0)
  shipping          Decimal  @db.Decimal(10, 2) @default(0)
  discounts         Decimal  @db.Decimal(10, 2) @default(0)
  total             Decimal  @db.Decimal(10, 2)
  paymentStatus     String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  fulfillmentStatus String   @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED
  billingAddress    Json?
  shippingAddress   Json?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  buyerOrg          Organization? @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  buyerUser         User?         @relation(fields: [buyerUserId], references: [id])
  sellerOrg         Organization  @relation("SellerOrg", fields: [sellerOrgId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  shipments         Shipment[]
  invoices          Invoice[]
  returns           Return[]
  commissions       Commission[]

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  variantId   String
  qty         Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  currency    String   @default("MXN")
  taxRate     Decimal  @db.Decimal(5, 4) @default(0)
  totalLine   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  // Relations
  order       Order   @relation(fields: [orderId], references: [id])
  variant     Variant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ===== PAYMENT ENTITIES =====

model Payment {
  id          String   @id @default(cuid())
  orderId     String
  provider    String   // STRIPE, PAYPAL, SPEI, PIX
  intentId    String?  // External payment intent ID
  status      String   @default("PENDING") // PENDING, SUCCEEDED, FAILED, CANCELLED
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("MXN")
  fee         Decimal  @db.Decimal(10, 2) @default(0)
  net         Decimal  @db.Decimal(10, 2)
  metadata    Json?
  capturedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  order       Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ===== QUOTATION ENTITIES =====

model Quote {
  id              String   @id @default(cuid())
  productId       String?
  variantId       String?
  requesterOrgId  String
  sellerOrgId     String
  status          String   @default("PENDING") // PENDING, QUOTED, ACCEPTED, REJECTED, EXPIRED
  requestData     Json     // Original request details
  offer           Json?    // Seller's offer details
  financingOptions Json?   // Lease/financing options
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  product         Product?      @relation(fields: [productId], references: [id])
  requesterOrg    Organization  @relation("RequesterOrgQuote", fields: [requesterOrgId], references: [id])
  sellerOrg       Organization  @relation("SellerOrgQuote", fields: [sellerOrgId], references: [id])

  @@map("quotes")
}

// ===== SHIPPING ENTITIES =====

model Shipment {
  id         String   @id @default(cuid())
  orderId    String
  carrier    String?  // DHL, FEDEX, ESTAFETA
  trackingId String?
  status     String   @default("PENDING") // PENDING, PICKED_UP, IN_TRANSIT, DELIVERED
  events     Json[]   // Array of tracking events
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  order      Order @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

model Return {
  id        String   @id @default(cuid())
  orderId   String
  items     Json     // Array of returned items
  reason    String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  order     Order @relation(fields: [orderId], references: [id])

  @@map("returns")
}

// ===== INVOICING ENTITIES =====

model Invoice {
  id           String   @id @default(cuid())
  orderId      String
  organizationId String
  cfdiUuid     String?  // Mexico CFDI UUID
  xmlUrl       String?
  pdfUrl       String?
  status       String   @default("PENDING") // PENDING, ISSUED, CANCELLED
  rfcEmisor    String?
  rfcReceptor  String?
  formaPago    String?  // CFDI payment method
  usoCFDI      String?  // CFDI usage
  total        Decimal  @db.Decimal(10, 2)
  currency     String   @default("MXN")
  issuedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  order        Order        @relation(fields: [orderId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("invoices")
}

// ===== SUBSCRIPTION & MONETIZATION ENTITIES =====

model Subscription {
  id             String   @id @default(cuid())
  organizationId String
  plan           String   // FREE, PRO, ELITE
  status         String   @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE
  startedAt      DateTime @default(now())
  renewsAt       DateTime?
  cancelledAt    DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

model Commission {
  id        String   @id @default(cuid())
  orderId   String
  orgId     String
  kind      String   // B2B, B2C, APPOINTMENT
  rate      Decimal  @db.Decimal(5, 4) // Percentage as decimal
  amount    Decimal  @db.Decimal(10, 2)
  currency  String   @default("MXN")
  status    String   @default("PENDING") // PENDING, PAID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  order        Order        @relation(fields: [orderId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@map("commissions")
}

// ===== LOYALTY & REFERRAL ENTITIES =====

model LoyaltyEvent {
  id        String   @id @default(cuid())
  userId    String?
  orgId     String?
  type      String   // PURCHASE, REFERRAL, BONUS, REDEMPTION
  points    Int
  meta      Json?    // Additional event data
  createdAt DateTime @default(now())

  // Relations
  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])

  @@map("loyalty_events")
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  bonus       Decimal  @db.Decimal(10, 2) @default(0)
  status      String   @default("PENDING") // PENDING, COMPLETED, EXPIRED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  referrer    User @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred    User @relation("ReferredUser", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@map("referrals")
}

// ===== REVIEW ENTITIES =====

model Review {
  id               String   @id @default(cuid())
  userId           String
  productId        String
  rating           Int      // 1-5
  comment          String?
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user             User    @relation(fields: [userId], references: [id])
  product          Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

// ===== EXCHANGE RATE ENTITIES =====

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String   // Base currency (e.g., MXN)
  quote     String   // Quote currency (e.g., USD)
  rate      Decimal  @db.Decimal(12, 6)
  fetchedAt DateTime @default(now())

  @@unique([base, quote, fetchedAt])
  @@map("exchange_rates")
}

// ===== WEBHOOK & AUDIT ENTITIES =====

model WebhookEvent {
  id         String   @id @default(cuid())
  source     String   // STRIPE, PAYPAL, SPEI, PIX
  externalId String?
  dedupeKey  String   @unique // For idempotency
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  processedAt DateTime?

  @@map("webhook_events")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actor     String   // User email or system identifier
  action    String   // CREATE, UPDATE, DELETE, etc.
  entity    String   // Entity type
  entityId  String   // Entity ID
  before    Json?    // Previous state
  after     Json?    // New state
  createdAt DateTime @default(now())

  // Relations
  user      User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ===== BACKUP & EXPORT ENTITIES =====

model ExportJob {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CSV, ZIP
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User @relation(fields: [userId], references: [id])

  @@map("export_jobs")
}